<!DOCTYPE html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content="{{ eleventy.generator }}" />

    <title>{{ pkg.name | capitalize }} | {{ name }}</title>
    <meta
      name="description"
      content="{{ description | default(pkg.description, true) }}"
    />

    <link rel="canonical" href="{{ page.url | htmlBaseUrl(pkg.author.url) }}" />

    <link
      rel="stylesheet"
      href="{{ pkg.author.url }}/normcore/css/normcore.css"
    />
    <link rel="stylesheet" href="/public/style.css" />
  </head>
  <body class="[ h-resume ] [ center stack ]" typeof="schema:Person">
    <header role="banner">
      <h1 class="p-name">{{ name or site.name }}</h1>
    </header>

    <main class="stack" role="main">
      {{ content | safe }}
    </main>
  </body>
</html>
